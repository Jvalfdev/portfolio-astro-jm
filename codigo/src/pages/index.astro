import SectionExperience from "../components/SectionExperience.astro";
import SectionEducation from "../components/SectionEducation.astro";
import SectionProjects from "../components/SectionProjects.astro";
import SectionContact from "../components/SectionContact.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout>
	<a class="skip-link" href="#sobre-mi" data-i18n="skip">Saltar al contenido</a>
	<SiteHeader />
	<main id="contenido">
		<Hero />
		<SectionAbout />
		<SectionExperience />
		<SectionEducation />
		<SectionProjects />
		<SectionContact />
	</main>
	<SiteFooter />
</BaseLayout>
