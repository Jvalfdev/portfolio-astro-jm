---
import { projects } from "../data/site.ts";
---

<section id="proyectos" class="wrap" aria-labelledby="proj-heading">
	<p class="section-label" data-i18n="proj.label">{projects.sectionLabel}</p>
	<div class="section-head">
		<h2 id="proj-heading" data-i18n="proj.headline">Enlaces y demostraciones</h2>
		<p class="text-muted" data-i18n="proj.intro">{projects.intro}</p>
	</div>
	<div>
		{projects.items.map((item, i) => (
			<article class="project-card">
				<h3 data-i18n={`proj${i}.name`}>{item.name}</h3>
				<p data-i18n={`proj${i}.desc`}>{item.description}</p>
				<div class="project-meta">
					<a href={item.href} target="_blank" rel="noopener noreferrer" data-i18n="proj.link">
						Ver enlace →
					</a>
					<span class="text-muted" data-i18n={`proj${i}.stack`}>
						{item.stack.join(" · ")}
					</span>
				</div>
			</article>
		))}
	</div>
</section>
