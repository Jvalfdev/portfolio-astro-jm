---
import { experience } from "../data/site.ts";

const formatRange = (from: string, to: string) => `${from} — ${to}`;
---

<section id="experiencia" class="wrap" aria-labelledby="exp-heading">
	<p class="section-label" data-i18n="exp.label">02 — Experiencia</p>
	<div class="section-head">
		<h2 id="exp-heading" data-i18n="exp.headline">Trayectoria profesional</h2>
		<p class="text-muted" data-i18n="exp.sub">
			Roles y tecnologías por etapa. Ajustá los textos a tu situación real.
		</p>
	</div>
	<div class="job-list">
		{experience.map((job, ji) => (
			<article class="job-card">
				<p class="job-meta" data-i18n={`job${ji}.range`}>
					{formatRange(job.from, job.to)}
				</p>
				<h3 class="job-title">
					<span data-i18n={`job${ji}.title`}>{job.title}</span>
					<span class="job-company">
						{" · "}
						{job.company}
						{job.location && (
							<>
								{" · "}
								<span class="text-muted" data-i18n={`job${ji}.loc`}>
									{job.location}
								</span>
							</>
						)}
					</span>
				</h3>
				<p class="job-summary" data-i18n={`job${ji}.sum`}>
					{job.summary}
				</p>
				<div class="job-tags">
					{job.tags.map((tag) => (
						<span>{tag}</span>
					))}
				</div>
			</article>
		))}
	</div>
</section>
